# xiuxian helper 多账户版示例配置
# 复制为 .env 后按需修改；不要提交真实配置。

# -----------------------------
# 系统级配置（Web + 全局存储）
# -----------------------------
APP_DB_PATH=xiuxian_app.sqlite3
LOG_DIR=logs
# 可选：统一管理 Telethon session 文件目录；Docker 部署建议设为 /app/data/sessions
SESSION_ROOT_DIR=
LOG_LEVEL=INFO

WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=changeme
WEB_SECRET_KEY=please_change_me

# 当首次从旧版单账号配置自动迁移时，若旧配置里没有账号名，则使用这个默认值
DEFAULT_ACCOUNT_NAME=default

# --------------------------------------------------------
# 可选：旧版单账号自动迁移区（仅在 accounts 表为空时读取）
# --------------------------------------------------------
# 如果你是从旧版升级，可以先把下面这一套旧字段保留在 .env 中。
# 程序第一次启动 Web 服务时，会自动把它迁移为 sqlite 里的第一个账号。
# 迁移完成后，建议改为只保留上面的系统级配置，账号改到网页里维护。

# Telegram API（从 https://my.telegram.org 获取）
TG_API_ID=123456
TG_API_HASH=your_api_hash_here
TG_SESSION_NAME=xiuxian_private_session

# 游戏群组与话题（forum topic root message id）
GAME_CHAT_ID=-1001234567890
TOPIC_ID=1234567
MY_NAME=YourName
SEND_TO_TOPIC=0

# 闭关
ACTION_CMD_BIGUAN=.闭关修炼
BIGUAN_EXTRA_BUFFER_SECONDS=60
BIGUAN_COOLDOWN_JITTER_MIN_SECONDS=5
BIGUAN_COOLDOWN_JITTER_MAX_SECONDS=15
BIGUAN_RETRY_JITTER_MIN_SECONDS=3
BIGUAN_RETRY_JITTER_MAX_SECONDS=8

# 发送与安全
DRY_RUN=0
GLOBAL_SEND_MIN_INTERVAL_SECONDS=10
GLOBAL_SENDS_PER_MINUTE=6
PLUGIN_SENDS_PER_MINUTE=3

# 插件开关
ENABLE_BIGUAN=1
ENABLE_DAILY=0
ENABLE_GARDEN=0
ENABLE_XINGGONG=0
ENABLE_YUANYING=0
ENABLE_CHUANGTA=0
ENABLE_ZONGMEN=0

# 小药园
GARDEN_SEED_NAME=清灵草种子
GARDEN_POLL_INTERVAL_SECONDS=3600
GARDEN_ACTION_SPACING_SECONDS=25

# 星宫
XINGGONG_STAR_NAME=庚金星
XINGGONG_POLL_INTERVAL_SECONDS=3600
XINGGONG_ACTION_SPACING_SECONDS=25
XINGGONG_QIZHEN_START_TIME=07:00
XINGGONG_QIZHEN_RETRY_INTERVAL_SECONDS=120
XINGGONG_QIZHEN_SECOND_OFFSET_SECONDS=43500
ENABLE_XINGGONG_WENAN=1
XINGGONG_WENAN_INTERVAL_SECONDS=43200
ENABLE_XINGGONG_DEEP_BIGUAN=0
ENABLE_XINGGONG_GUANXING=0
XINGGONG_GUANXING_TARGET_USERNAME=salt9527
XINGGONG_GUANXING_PREVIEW_ADVANCE_SECONDS=180
XINGGONG_GUANXING_SHIFT_ADVANCE_SECONDS=1
XINGGONG_GUANXING_WATCH_EVENTS=星辰异象,地磁暴动

# 元婴 / 闯塔
YUANYING_CHUQIAO_INTERVAL_SECONDS=28800
YUANYING_LIEFENG_INTERVAL_SECONDS=43200
CHUANGTA_TIME=14:15

# 宗门
ZONGMEN_CMD_DIANMAO=.宗门点卯
ZONGMEN_DIANMAO_TIME=09:37
ZONGMEN_CMD_CHUANGONG=.宗门传功
ZONGMEN_CHUANGONG_TIMES=09:38,09:40,09:43
ZONGMEN_CHUANGONG_XINDE_TEXT=宗门传功
ZONGMEN_CATCH_UP=1
ZONGMEN_ACTION_SPACING_SECONDS=20
